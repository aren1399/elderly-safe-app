#:kivy 2.0
# 老年防走失安全守护 - UI 布局

<LargeButton@Button>:
    # 大号按钮样式
    font_size: '28sp'
    bold: True
    size_hint: 0.85, None
    height: '90dp'
    pos_hint: {'center_x': 0.5}
    background_normal: ''
    border: 0, 0, 0, 0

<GiantButton@Button>:
    # 巨型按钮 - 主操作按钮
    font_size: '36sp'
    bold: True
    size_hint: 0.9, None
    height: '140dp'
    pos_hint: {'center_x': 0.5}
    background_normal: ''
    border: 0, 0, 0, 0

<ContactButton@Button>:
    # 联系人按钮
    font_size: '24sp'
    size_hint: 0.85, None
    height: '80dp'
    pos_hint: {'center_x': 0.5}
    background_normal: ''
    border: 0, 0, 0, 0

# ==================== 主页面 ====================

<MainScreen>:
    name: 'main'
    BoxLayout:
        orientation: 'vertical'
        padding: '25dp'
        spacing: '20dp'

        # 顶部状态栏
        BoxLayout:
            size_hint: 1, 0.08
            Label:
                text: '🏠 安全守护'
                font_size: '32sp'
                bold: True
                color: 0.1, 0.3, 0.6, 1
                halign: 'center'
                valign: 'middle'

        # 状态显示区
        BoxLayout:
            id: status_box
            size_hint: 1, 0.3
            orientation: 'vertical'
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20]
            padding: '20dp'

            Label:
                id: status_label
                text: '未开启守护\\n\\n请点击下方按钮开始'
                font_size: '26sp'
                halign: 'center'
                valign: 'middle'
                color: 0.3, 0.3, 0.3, 1

            Label:
                id: info_label
                text: ''
                font_size: '20sp'
                halign: 'center'
                valign: 'middle'
                color: 0.5, 0.5, 0.5, 1

        # 按钮区
        BoxLayout:
            size_hint: 1, 0.55
            orientation: 'vertical'
            spacing: '18dp'

            GiantButton:
                id: start_btn
                text: '开始守护'
                background_color: 0.2, 0.7, 0.3, 1
                color: 1, 1, 1, 1
                on_press: root.start_guard()

            GiantButton:
                id: stop_btn
                text: '安全到家'
                background_color: 0.9, 0.3, 0.3, 1
                color: 1, 1, 1, 1
                disabled: True
                opacity: 0.4 if self.disabled else 1
                on_press: root.stop_guard()

            LargeButton:
                text: '⚙ 设置'
                background_color: 0.5, 0.5, 0.6, 1
                color: 1, 1, 1, 1
                size_hint: 0.5, None
                height: '70dp'
                pos_hint: {'center_x': 0.5}
                on_press: root.go_settings()

# ==================== 设置页面 ====================

<SettingsScreen>:
    name: 'settings'
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            padding: '25dp'
            spacing: '18dp'
            size_hint: 1, None
            height: self.minimum_height

            Label:
                text: '⚙ 设置'
                font_size: '32sp'
                bold: True
                size_hint: 1, None
                height: '60dp'
                color: 0.1, 0.3, 0.6, 1

            # 家的位置
            Label:
                text: '家的位置'
                font_size: '24sp'
                bold: True
                size_hint: 1, None
                height: '40dp'
                color: 0.2, 0.2, 0.2, 1

            Label:
                id: home_address_label
                text: '未设置'
                font_size: '22sp'
                size_hint: 1, None
                height: '50dp'
                color: 0.4, 0.4, 0.4, 1

            LargeButton:
                id: set_home_btn
                text: '📍 设为家的位置'
                background_color: 0.2, 0.6, 0.8, 1
                color: 1, 1, 1, 1
                on_press: root.set_home_location()

            # 紧急联系人
            Label:
                text: '紧急联系人'
                font_size: '24sp'
                bold: True
                size_hint: 1, None
                height: '40dp'
                color: 0.2, 0.2, 0.2, 1

            Label:
                id: contacts_label
                text: '未设置联系人'
                font_size: '22sp'
                size_hint: 1, None
                height: '50dp'
                color: 0.4, 0.4, 0.4, 1

            BoxLayout:
                size_hint: 1, None
                height: '80dp'
                spacing: '10dp'

                TextInput:
                    id: phone_input
                    text: ''
                    hint_text: '输入手机号码'
                    font_size: '24sp'
                    size_hint: 0.65, 1
                    multiline: False
                    input_filter: 'int'

                LargeButton:
                    text: '添加'
                    font_size: '24sp'
                    size_hint: 0.3, None
                    height: '80dp'
                    background_color: 0.2, 0.6, 0.8, 1
                    color: 1, 1, 1, 1
                    pos_hint: {}
                    on_press: root.add_contact(phone_input.text)

            # 预设路线
            Label:
                text: '预设路线（家人设置）'
                font_size: '24sp'
                bold: True
                size_hint: 1, None
                height: '40dp'
                color: 0.2, 0.2, 0.2, 1

            Label:
                id: route_label
                text: '未设置路线'
                font_size: '20sp'
                size_hint: 1, None
                height: '60dp'
                color: 0.4, 0.4, 0.4, 1

            BoxLayout:
                size_hint: 1, None
                height: '80dp'
                spacing: '8dp'

                LargeButton:
                    text: '📍 添加途经点'
                    font_size: '20sp'
                    size_hint: 0.45, None
                    height: '80dp'
                    background_color: 0.2, 0.6, 0.8, 1
                    color: 1, 1, 1, 1
                    pos_hint: {}
                    on_press: root.add_route_point()

                LargeButton:
                    text: '🗑 清空路线'
                    font_size: '20sp'
                    size_hint: 0.45, None
                    height: '80dp'
                    background_color: 0.9, 0.4, 0.2, 1
                    color: 1, 1, 1, 1
                    pos_hint: {}
                    on_press: root.clear_route()

            # 安全范围
            Label:
                text: '安全范围'
                font_size: '24sp'
                bold: True
                size_hint: 1, None
                height: '40dp'
                color: 0.2, 0.2, 0.2, 1

            BoxLayout:
                size_hint: 1, None
                height: '60dp'
                spacing: '10dp'

                Label:
                    text: '最大距离（米）'
                    font_size: '22sp'
                    size_hint: 0.5, 1
                    color: 0.3, 0.3, 0.3, 1

                Slider:
                    id: distance_slider
                    min: 100
                    max: 3000
                    value: 500
                    step: 100
                    size_hint: 0.5, 1
                    on_value: root.on_distance_slider()

            Label:
                id: distance_label
                text: '500 米'
                font_size: '22sp'
                size_hint: 1, None
                height: '30dp'
                halign: 'center'
                color: 0.5, 0.5, 0.5, 1

            # 外出时长
            Label:
                text: '外出时长限制'
                font_size: '24sp'
                bold: True
                size_hint: 1, None
                height: '40dp'
                color: 0.2, 0.2, 0.2, 1

            BoxLayout:
                size_hint: 1, None
                height: '60dp'
                spacing: '10dp'

                Label:
                    text: '最长时间（分钟）'
                    font_size: '22sp'
                    size_hint: 0.5, 1
                    color: 0.3, 0.3, 0.3, 1

                Slider:
                    id: time_slider
                    min: 10
                    max: 480
                    value: 60
                    step: 10
                    size_hint: 0.5, 1
                    on_value: root.on_time_slider()

            Label:
                id: time_label
                text: '60 分钟'
                font_size: '22sp'
                size_hint: 1, None
                height: '30dp'
                halign: 'center'
                color: 0.5, 0.5, 0.5, 1

            # 语音开关
            BoxLayout:
                size_hint: 1, None
                height: '60dp'
                spacing: '10dp'

                Label:
                    text: '语音播报'
                    font_size: '24sp'
                    size_hint: 0.5, 1
                    color: 0.2, 0.2, 0.2, 1

                Switch:
                    id: voice_switch
                    active: True
                    size_hint: 0.5, 1

            # 返回按钮
            LargeButton:
                text: '✓ 保存并返回'
                background_color: 0.2, 0.7, 0.3, 1
                color: 1, 1, 1, 1
                size_hint: 0.7, None
                height: '80dp'
                pos_hint: {'center_x': 0.5}
                on_press: root.save_and_back()

# ==================== 告警页面 ====================

<AlertScreen>:
    name: 'alert'
    BoxLayout:
        orientation: 'vertical'
        padding: '25dp'
        spacing: '15dp'
        canvas.before:
            Color:
                rgba: 0.85, 0.1, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            id: alert_title
            text: '⚠️ 安全告警'
            font_size: '36sp'
            bold: True
            size_hint: 1, 0.1
            color: 1, 1, 0.3, 1

        Label:
            id: alert_message
            text: ''
            font_size: '24sp'
            size_hint: 1, 0.25
            color: 1, 1, 1, 1
            halign: 'center'
            valign: 'middle'

        Label:
            id: alert_location
            text: '正在获取位置信息...'
            font_size: '18sp'
            size_hint: 1, 0.25
            color: 1, 1, 1, 0.9
            halign: 'center'
            valign: 'middle'

        BoxLayout:
            id: contact_buttons
            size_hint: 1, 0.3
            orientation: 'vertical'
            spacing: '10dp'

        GiantButton:
            text: '✓ 我没事'
            background_color: 0.2, 0.7, 0.3, 1
            color: 1, 1, 1, 1
            size_hint: 0.7, None
            height: '100dp'
            pos_hint: {'center_x': 0.5}
            on_press: root.dismiss_alert()
